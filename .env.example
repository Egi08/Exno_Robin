# ── Telegram (WAJIB) ──
TELEGRAM_BOT_TOKEN=isi_token_dari_BotFather
ALLOWED_USER_IDS=123456789        # chat ID kamu; kosong = semua orang bisa pakai (JANGAN)

# ── AI (OpenAI-compatible; utama + cadangan) ──
AI_BASE_URL=https://api.siliconflow.com/v1/chat/completions
AI_API_KEY=sk-isi_api_key
AI_MODEL=tencent/Hy3
AI2_BASE_URL=                      # opsional: endpoint cadangan kalau utama lambat/error
AI2_API_KEY=
AI2_MODEL=

# ── Chain — Robinhood Chain mainnet ──
RPC_URL=https://rpc.mainnet.chain.robinhood.com
RPC_URL_FALLBACK=                  # opsional (mis. Alchemy); kosong = tidak dipakai
CHAIN_ID=4663
NETWORK_SLUG=robinhood
WETH_ADDRESS=0x0bd7d308f8e1639fab988df18a8011f41eacad73
USDG_ADDRESS=0x5fc5360d0400a0fd4f2af552add042d716f1d168
QUOTE_TOKEN=USDG                   # USDG atau WETH — quote posisi LP
UNIV3_POSITION_MANAGER=0x73991a25c818bf1f1128deaab1492d45638de0d3
UNIV3_FACTORY=0x1f7d7550b1b028f7571e69a784071f0205fd2efa

# ── Wallet (pakai wallet BARU khusus bot, saldo kecil!) ──
PRIVATE_KEY=0x...

# ── Mode ──
DRY_RUN=true                       # true = simulasi; false = UANG ASLI tanpa konfirmasi
DRY_RUN_CAPITAL_USD=50

# ── Filter screening (metode fee-first, tf 24 jam) ──
MIN_VOL_24H_USD=1000000
MIN_MCAP_USD=500000
MIN_LIQUIDITY_USD=50000
MIN_VOL_5M_USD=100000              # fallback lama
DEX_BLACKLIST=flap,klik            # launchpad sarang scam
MIN_USDG_POOL_USD=500              # kedalaman min sisi USDG pool
MAX_POSITIONS=3

# ── Auto-cycle: screening -> analisis AI -> deploy tiap N menit (0 = mati) ──
AUTO_INTERVAL_MIN=5
AUTO_SIZE_PCT=90                   # % saldo per deploy (compound otomatis)
AUTO_ETH=0.01                      # ukuran tetap kalau AUTO_SIZE_PCT=0
GAS_RESERVE_ETH=0.0002
AUTO_PAUSE_WHEN_OPEN=true          # fokus 1 posisi; false = isi semua slot (sizing dibagi)
TWO_SIDED=true                     # dua sisi (in-range langsung); false = one-sided lower
TARGET_USD=200                     # target compounding; tercapai -> berhenti deploy

# ── Management agent (0 = mati) ──
MGMT_INTERVAL_MIN=5
MGMT_HEARTBEAT=true
STOP_LOSS_PCT=-25                  # dari net PnL real on-chain (harga + fee)
FEE_TP_PCT=30                      # auto-close saat fee >= % modal
OUT_OF_RANGE_CLOSE_MIN=30          # di atas range N menit -> jual, cari koin baru
MIN_POOL_VOL_ALERT_USD=500000
TOKEN_COOLDOWN_H=24                # koin baru ditutup dilarang dipilih lagi N jam
REBAL_ABOVE_PCT=0                  # auto-rebalance; 0 = mati (disarankan)
